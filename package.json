{
  "name": "pookie-hampers",
  "version": "1.0.0",
  "description": "The cutest gifts for your favorite pookies - Hamper customizer & e-commerce",
  "author": "Tanvi",
  "license": "MIT",
  "keywords": [
    "hampers",
    "gifts",
    "e-commerce",
    "tailwind",
    "coquette",
    "customizer"
  ],
  "scripts": {
    "dev": "http-server . -p 8000 -c-1",
    "build": "tailwindcss -i src/css/input.css -o src/css/output.css --minify",
    "watch": "tailwindcss -i src/css/input.css -o src/css/output.css --watch",
    "start": "http-server . -p 8000"
  },
  "devDependencies": {
    "tailwindcss": "^3.4.0",
    "postcss": "^8.4.31"
  },
  "dependencies": {
    "axios": "^1.6.0"
  }
}
